# This .env.dev file defines environment variables for a local development environment,
# aligned with the services configured in the docker-compose.yml file. It is used to
# configure the server for local testing and development.
#
# Usage: admiral COMMAND --config config.yaml --env .env.dev
#

# Server
EXTERNAL_URL=http://localhost:8080
LOGGER_LEVEL=debug

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=admiral
DATABASE_USER=admiral
DATABASE_PASSWORD=shipitnow
DATABASE_SSL_MODE=disable

# Session
SESSION_IDLE_TIMEOUT=30m
SESSION_LIFETIME=24h
SESSION_COOKIE_NAME=session
SESSION_COOKIE_DOMAIN=""
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_PERSIST=true

# Authentication
AUTHN_NAME=keycloak
AUTHN_ISSUER=http://localhost:9090/realms/admiral
AUTHN_CLIENT_ID=admiral
AUTHN_CLIENT_SECRET=j10AhU98vlDegAC6dgroYc8HmvfHMEvh
AUTHN_SCOPES=openid,offline_access,email,profile
AUTHN_REDIRECT_URL=http://localhost:8888/auth/callback
AUTHN_SIGNING_SECRET=3e0e6c2a5e88f1782880cbd1cf21e76529c5f13d6ea6cd32fb63870b5db5c2de
AUTHN_REFRESH_TOKEN_TTL=12h

# Encryption (base64-encoded 32-byte AES-256 key)
ENCRYPTION_ACTIVE_KEY=4bWCrgt9dJejJ7W3laX9sXVG5+u8iu9KX5ypDoYbOEk=
ENCRYPTION_OLD_KEY=

# Storage
STORAGE_TYPE=s3
STORAGE_BUCKET=admiral
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=admiral
STORAGE_SECRET_KEY=shipitnow
STORAGE_USE_SSL=false
