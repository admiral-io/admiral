{
package querybuilder

import (
	"strconv"
	"strings"
)

type Query struct {
	AndFields []*Field
}

type Field struct {
	Key       *Source
	Operation string
	Value     any
}

type Source struct {
	Kind string
	Name string
}

func makeQuery(firstField, restFields any) (*Query, error) {
	q := &Query{}
	q.AndFields = []*Field{ firstField.(*Field) }

	rfs := restFields.([]any)
	for _, rf := range rfs {
		q.AndFields = append(q.AndFields, rf.(*Field))
	}
	return q, nil
}

func makeField(src, op, val any) (any, error) {
	return &Field{
		Key:       src.(*Source),
		Operation: op.(string),
		Value:     val,
	}, nil
}

func makeSource(kind, name any) (any, error) {
	return &Source{
		Kind: kind.(string),
		Name: name.(string),
	}, nil
}

func makeValue(val any) (any, error) {
	return val, nil
}

}

// Top-level Query (with possible multiple Fields separated by optional AND)
Query
  = firstField:Field restFields:( _ ("AND"i _)? f:Field { return f, nil } )* _ EOF {
      return makeQuery(firstField, restFields)
  }

// A single Field consists of a Source, an Operator, and a Value
Field
  = src:Source _ op:Operator _ value:Value {
      return makeField(src, op, value)
  }

// Source can be either field[...] or meta[...]
Source
  = FieldSource / MetaSource

 FieldSource
  = "field[" _ key:String _ "]" {
      return makeSource("field", key)
  }

MetaSource
  = "meta[" _ key:String _ "]" {
      return makeSource("meta", key)
  }

// Operators recognized
Operator
  = (
      "~="
    / "!="
    / "<="
    / ">="
    / "="
    / "<"
    / ">"
  ) {
      return string(c.text), nil
  }

// Value can be float, int, bool, identifier, or string
Value
  = val:(
      Float
    / Integer
    / Boolean
    / Identifier
    / String
    ) {
      return makeValue(val)
    }

// Float requires a decimal point or exponent to distinguish from Integer
Float
  = [+-]? [0-9]+ "." [0-9]* ([eE][+-]?[0-9]+)? {
      text := string(c.text)
      val, err := strconv.ParseFloat(text, 64)
      if err != nil {
          return nil, err
      }
      return val, nil
    }
  / [+-]? [0-9]+ [eE][+-]?[0-9]+ {
      text := string(c.text)
      val, err := strconv.ParseFloat(text, 64)
      if err != nil {
          return nil, err
      }
      return val, nil
    }

// Integer parsing
Integer
  = [+-]? [0-9]+ {
      text := string(c.text)
      val, err := strconv.ParseInt(text, 10, 64)
      if err != nil {
          return nil, err
      }
      return val, nil
    }

// Boolean parsing
Boolean
  = ("false"i / "true"i) {
      text := string(c.text)
      val, err := strconv.ParseBool(text)
      if err != nil {
          return nil, err
      }
      return val, nil
    }

// String can be single-quoted or double-quoted (with naive escapes)
String
  = SingleQuoteString / DoubleQuoteString

SingleQuoteString
  = "'" ( "\\'" / !"'" . )* "'" {
      text := string(c.text)
      // strip outer quotes
      inner := text[1:len(text)-1]
      // unescape \'
      unescaped := strings.ReplaceAll(inner, "\\'", "'")
      return unescaped, nil
    }

DoubleQuoteString
  = '"' ( "\\\"" / !'"' . )* '"' {
      text := string(c.text)
      // strip outer quotes
      inner := text[1:len(text)-1]
      // unescape \"
      unescaped := strings.ReplaceAll(inner, "\\\"", "\"")
      return unescaped, nil
    }

// Identifier: starts with letter/underscore, can contain letters/digits/underscore/dots
Identifier
  = [a-zA-Z_][a-zA-Z0-9_]*( "." [a-zA-Z0-9_]+ )* {
      return string(c.text), nil
    }

// Optional whitespace
_ "whitespace"
  = [ \n\r\t]*

// End of file
EOF
  = !.
