{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "openapi-typescript ../../admiral-protos/build/repo/admiral-openapi/openapi.v3.yaml -o src/services/api.d.ts",
    "build": "tsc -b && vite build",
    "dev": "vite",
    "format": "prettier --ignore-path ../.gitignore --write \"**/*.+(js|jsx|ts|tsx|json|css|scss)\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:packages": "sort-package-json package.json --check",
    "lint:packages:fix": "sort-package-json package.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@reduxjs/toolkit": "^2.11.2",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "redux-logger": "^3.0.6",
    "redux-persist": "^6.0.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/redux-logger": "^3.0.13",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.99.0",
    "sort-package-json": "^3.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
