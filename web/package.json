    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2",
    "redux-logger": "^3.0.6",
    "redux-persist": "^6.0.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
